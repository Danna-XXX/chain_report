# 复制此文件为 .env，填入真实 API Key
# Copy this file to .env and fill in your real API keys

# 阿里云 DashScope API Key（Qwen 系列，用于正文生成）
# 获取地址：https://dashscope.aliyun.com/
ALIYUN_API_KEY=sk-your-aliyun-dashscope-key-here

# 硅基流动 API Key（GLM-5.1，用于 Planner / Critic / 摘要）
# 获取地址：https://siliconflow.cn/
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# Tavily API Key（联网检索，优先于 DuckDuckGo / Bing）
# 获取地址：https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-key-here
